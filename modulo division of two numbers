# modulo division of two numbers take input from the user
n1=int(input("enter the first number:"))
n2=int(input("enter the second number:"))
if n2!=0:
    remainder=n1%n2
    print("modulo division of two numbers = ",remainder)
else:
    print("error! modulo division is not possible")

